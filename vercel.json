{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "functions": {
    "agent.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    },
    "mcp_server/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/agent", "dest": "/agent.ts" },
    { "src": "/api/mcp", "dest": "/mcp_server/index.ts" },
    { "src": "/(.*)", "dest": "/agent.ts" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
